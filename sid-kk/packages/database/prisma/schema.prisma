// Sistem Informasi Desa Kasomalang Kulon (SID-KK)
// Prisma Schema - Enterprise Grade

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================
// AUTHENTICATION & AUTHORIZATION
// ============================================

model User {
  id                String    @id @default(uuid())
  email             String    @unique
  username          String    @unique
  password          String
  fullName          String
  phone             String?
  avatar            String?
  isActive          Boolean   @default(true)
  lastLoginAt       DateTime?
  lastLoginIp       String?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  deletedAt         DateTime?

  // Relations
  roleId            String
  role              Role      @relation(fields: [roleId], references: [id])
  
  // RT/Kolektor specific
  rtId              String?
  rt                Rt?       @relation(fields: [rtId], references: [id])
  
  // Kolektor PBB
  kolektorPbbId     String?
  kolektorPbb       KolektorPbb? @relation(fields: [kolektorPbbId], references: [id])

  // Audit logs
  auditLogs         AuditLog[]
  
  // Login history
  loginHistories    LoginHistory[]

  @@map("users")
}

model Role {
  id          String   @id @default(uuid())
  name        String   @unique // SUPER_ADMIN, ADMIN_DESA, RT, KOLEKTOR_PBB, MASYARAKAT
  displayName String
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  users       User[]
  permissions Permission[]

  @@map("roles")
}

model Permission {
  id          String   @id @default(uuid())
  name        String   @unique // e.g., pbb.read, pbb.write, surat.approve
  displayName String
  description String?
  module      String   // pbb, surat, bantuan, penduduk, pengaduan, berita, master
  createdAt   DateTime @default(now())

  // Relations
  roles       Role[]

  @@map("permissions")
}

model LoginHistory {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  ipAddress String
  userAgent String?
  status    String   // SUCCESS, FAILED
  reason    String?
  createdAt DateTime @default(now())

  @@map("login_histories")
}

// ============================================
// WILAYAH ADMINISTRATIF
// ============================================

model Dusun {
  id          String   @id @default(uuid())
  name        String
  code        String   @unique
  description String?
  headName    String?
  headPhone   String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  rws         Rw[]
  pbbStats    PbbStatDusun[]

  @@map("dusun")
}

model Rw {
  id          String   @id @default(uuid())
  name        String
  code        String   @unique
  dusunId     String
  dusun       Dusun    @relation(fields: [dusunId], references: [id])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  rts         Rt[]
  pbbStats    PbbStatRw[]

  @@unique([dusunId, name])
  @@map("rw")
}

model Rt {
  id          String   @id @default(uuid())
  name        String
  code        String   @unique
  rwId        String
  rw          Rw       @relation(fields: [rwId], references: [id])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  users       User[]
  wajibPajaks WajibPajak[]
  pbbStats    PbbStatRt[]

  @@unique([rwId, name])
  @@map("rt")
}

// ============================================
// KEPENDUDUKAN
// ============================================

model Keluarga {
  id              String   @id @default(uuid())
  noKk            String   @unique
  address         String
  rtId            String
  rt              Rt       @relation(fields: [rtId], references: [id])
  postalCode      String?
  phone           String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  // Relations
  members         Penduduk[]

  @@map("keluarga")
}

enum Gender {
  LAKI_LAKI
  PEREMPUAN
}

enum StatusPerkawinan {
  BELUM_KAWIN
  KAWIN
  CERAI_HIDUP
  CERAI_MATI
}

model Penduduk {
  id                String           @id @default(uuid())
  nik               String           @unique
  noKk              String
  familyId          String
  family            Keluarga         @relation(fields: [familyId], references: [id], onDelete: Cascade)
  fullName          String
  birthPlace        String
  birthDate         DateTime
  gender            Gender
  religion          String
  education         String
  occupation        String?
  maritalStatus     StatusPerkawinan
  bloodType         String?
  phone             String?
  isHeadOfFamily    Boolean          @default(false)
  status            String           @default('ACTIVE') // ACTIVE, MUTASI_MASUK, MUTASI_KELUAR, MENINGGAL, PINDAH
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt
  deletedAt         DateTime?

  // Relations
  wajibPajak        WajibPajak?

  @@index([nik])
  @@index([noKk])
  @@index([familyId])
  @@map("penduduk")
}

// ============================================
# PBB MODULE
// ============================================

model WajibPajak {
  id              String   @id @default(uuid())
  nop             String   @unique // Nomor Objek Pajak
  pendudukId      String   @unique
  penduduk        Penduduk @relation(fields: [pendudukId], references: [id])
  rtId            String
  rt              Rt       @relation(fields: [rtId], references: [id])
  objectAddress   String
  landArea        Decimal?
  buildingArea    Decimal?
  njop            Decimal?
  pbbAmount       Decimal?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  // Relations
  pbbRecords      Pbb[]
  pbbPayments     PbbPayment[]

  @@index([nop])
  @@index([rtId])
  @@map("wajib_pajak")
}

model Pbb {
  id              String   @id @default(uuid())
  year            Int
  wajibPajakId    String
  wajibPajak      WajibPajak @relation(fields: [wajibPajakId], references: [id])
  spptNo          String?
  tagihan         Decimal
  pokok           Decimal
  denda           Decimal?   @default(0)
  status          String   @default("BELUM_BAYAR") // BELUM_BAYAR, MENUNGGAK, LUNAS
  dueDate         DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  // Relations
  payments        PbbPayment[]

  @@unique([year, wajibPajakId])
  @@index([year])
  @@index([status])
  @@map("pbb")
}

model PbbPayment {
  id              String   @id @default(uuid())
  pbbId           String
  pbb             Pbb      @relation(fields: [pbbId], references: [id])
  wajibPajakId    String
  wajibPajak      WajibPajak @relation(fields: [wajibPajakId], references: [id])
  paymentDate     DateTime
  amount          Decimal
  proofImage      String
  proofDocument   String?
  notes           String?
  status          String   @default("PENDING") // PENDING, APPROVED, REJECTED
  verifiedBy      String?
  verifiedAt      DateTime?
  rejectionReason String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  // Relations
  verifications   PbbVerification[]

  @@index([pbbId])
  @@index([wajibPajakId])
  @@index([status])
  @@map("pbb_payments")
}

model PbbVerification {
  id              String   @id @default(uuid())
  paymentId       String
  payment         PbbPayment @relation(fields: [paymentId], references: [id])
  verifiedBy      String
  action          String   // APPROVE, REJECT
  notes           String?
  createdAt       DateTime @default(now())

  @@index([paymentId])
  @@map("pbb_verifications")
}

model KolektorPbb {
  id          String   @id @default(uuid())
  name        String
  code        String   @unique
  phone       String?
  areaDesc    String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  users       User[]

  @@map("kolektor_pbb")
}

// ============================================
// STATISTIK PBB (For Dashboard Analytics)
// ============================================

model PbbStatDusun {
  id          String   @id @default(uuid())
  year        Int
  dusunId     String
  dusun       Dusun    @relation(fields: [dusunId], references: [id])
  totalSppt   Int      @default(0)
  totalTagihan Decimal @default(0)
  totalBayar  Decimal @default(0)
  totalBelumBayar Decimal @default(0)
  countBayar  Int      @default(0)
  countBelumBayar Int  @default(0)
  realisasiPercent Decimal @default(0)
  updatedAt   DateTime @updatedAt

  @@unique([year, dusunId])
  @@map("pbb_stat_dusun")
}

model PbbStatRw {
  id          String   @id @default(uuid())
  year        Int
  rwId        String
  rw          Rw       @relation(fields: [rwId], references: [id])
  totalSppt   Int      @default(0)
  totalTagihan Decimal @default(0)
  totalBayar  Decimal @default(0)
  totalBelumBayar Decimal @default(0)
  countBayar  Int      @default(0)
  countBelumBayar Int  @default(0)
  realisasiPercent Decimal @default(0)
  updatedAt   DateTime @updatedAt

  @@unique([year, rwId])
  @@map("pbb_stat_rw")
}

model PbbStatRt {
  id          String   @id @default(uuid())
  year        Int
  rtId        String
  rt          Rt       @relation(fields: [rtId], references: [id])
  totalSppt   Int      @default(0)
  totalTagihan Decimal @default(0)
  totalBayar  Decimal @default(0)
  totalBelumBayar Decimal @default(0)
  countBayar  Int      @default(0)
  countBelumBayar Int  @default(0)
  realisasiPercent Decimal @default(0)
  updatedAt   DateTime @updatedAt

  @@unique([year, rtId])
  @@map("pbb_stat_rt")
}

// ============================================
# SURAT MENYURAT MODULE
// ============================================

enum SuratType {
  SKT
  SKU
  SKTM
  PENGANTAR_KTP
  PENGANTAR_KK
  SK_BELUM_MENIKAH
  SK_BEDA_NAMA
  SK_KEHILANGAN
  SK_KELAHIRAN
  SK_KEMATIAN
}

model Surat {
  id              String     @id @default(uuid())
  code            String     @unique
  name            String
  type            SuratType
  template        String     @db.Text
  requirements    String     @db.Text // JSON array of requirements
  fee             Decimal?   @default(0)
  isActive        Boolean    @default(true)
  processingDays  Int        @default(3)
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt

  // Relations
  requests        SuratRequest[]

  @@map("surat")
}

model SuratRequest {
  id              String   @id @default(uuid())
  requestNumber   String   @unique
  suratId         String
  surat           Surat    @relation(fields: [suratId], references: [id])
  pemohonId       String
  pemohonName     String
  pemohonNik      String
  pemohonPhone    String?
  pemohonEmail    String?
  purpose         String   @db.Text
  status          String   @default("DIAJUKAN") // DIAJUKAN, DIPROSES, DISETUJUI, DITOLAK, SELESAI
  attachments     String?  // JSON array of file URLs
  notes           String?
  approvedBy      String?
  approvedAt      DateTime?
  rejectedBy      String?
  rejectedAt      DateTime?
  rejectionReason String?
  completedAt     DateTime?
  pdfUrl          String?
  qrCode          String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([requestNumber])
  @@index([pemohonNik])
  @@index([status])
  @@map("surat_requests")
}

// ============================================
# BANTUAN SOSIAL MODULE
// ============================================

enum BantuanType {
  PKH
  BPNT
  BLT
  RUTILAHU
  PROGRAM_DESA
}

model BantuanSosial {
  id              String     @id @default(uuid())
  name            String
  type            BantuanType
  year            Int
  description     String?
  quota           Int?
  budget          Decimal?
  startDate       DateTime?
  endDate         DateTime?
  status          String     @default("ACTIVE") // ACTIVE, INACTIVE, COMPLETED
  criteria        String?    @db.Text
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt

  // Relations
  penerima        BantuanPenerima[]

  @@index([year])
  @@index([type])
  @@map("bantuan_sosial")
}

model BantuanPenerima {
  id              String   @id @default(uuid())
  bantuanId       String
  bantuan         BantuanSosial @relation(fields: [bantuanId], references: [id])
  pendudukId      String
  nik             String
  name            String
  familyId        String
  noKk            String
  address         String
  rtId            String
  score           Decimal?
  status          String   @default("VERIFIED") // PENDING, VERIFIED, REJECTED, DICAIRKAN
  notes           String?
  verificationBy  String?
  verificationAt  DateTime?
  disbursementDate DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([bantuanId])
  @@index([nik])
  @@map("bantuan_penerima")
}

// ============================================
# BERITA & PENGUMUMAN MODULE
// ============================================

model Berita {
  id          String   @id @default(uuid())
  title       String
  slug        String   @unique
  content     String   @db.Text
  excerpt     String?
  thumbnail   String?
  authorId    String
  category    String   @default("BERITA") // BERITA, PENGUMUMAN, AGENDA
  tags        String?  // JSON array
  views       Int      @default(0)
  isPublished Boolean  @default(false)
  publishedAt DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([slug])
  @@index([category])
  @@index([isPublished])
  @@map("berita")
}

// ============================================
# PENGADUAN MODULE
// ============================================

model Pengaduan {
  id              String   @id @default(uuid())
  reportNumber    String   @unique
  pelaporName     String
  pelaporPhone    String?
  pelaporEmail    String?
  category        String   // INFRASTRUKTUR, PELAYANAN, KEBERSIHAN, KEAMANAN, LAINNYA
  title           String
  content         String   @db.Text
  location        String?
  attachments     String?  // JSON array of file URLs
  status          String   @default("DITERIMA") // DITERIMA, DIPROSES, SELESAI, DITOLAK
  priority        String   @default("NORMAL") // LOW, NORMAL, HIGH, URGENT
  assignedTo      String?
  response        String?  @db.Text
  respondedBy     String?
  respondedAt     DateTime?
  resolvedAt      DateTime?
  isAnonymous     Boolean  @default(false)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([reportNumber])
  @@index([status])
  @@map("pengaduan")
}

// ============================================
# PROFIL DESA
// ============================================

model ProfilDesa {
  id              String   @id @default(uuid())
  key             String   @unique
  value           String   @db.Text
  category        String   @default("GENERAL")
  updatedAt       DateTime @updatedAt

  @@map("profil_desa")
}

// ============================================
# SYSTEM & AUDIT
// ============================================

model AuditLog {
  id          String   @id @default(uuid())
  userId      String?
  user        User?    @relation(fields: [userId], references: [id])
  action      String   // CREATE, UPDATE, DELETE, LOGIN, LOGOUT
  entity      String   // Table or module name
  entityId    String?
  oldData     String?  @db.Text // JSON
  newData     String?  @db.Text // JSON
  ipAddress   String?
  userAgent   String?
  createdAt   DateTime @default(now())

  @@index([userId])
  @@index([entity])
  @@index([action])
  @@map("audit_logs")
}

model Notification {
  id          String   @id @default(uuid())
  userId      String
  title       String
  message     String   @db.Text
  type        String   // INFO, WARNING, ERROR, SUCCESS
  isRead      Boolean  @default(false)
  link        String?
  createdAt   DateTime @default(now())

  @@index([userId])
  @@index([isRead])
  @@map("notifications")
}

model Session {
  id           String   @id @default(uuid())
  userId       String
  token        String   @unique
  refreshToken String?  @unique
  expiresAt    DateTime
  ipAddress    String?
  userAgent    String?
  createdAt    DateTime @default(now())

  @@index([userId])
  @@index([token])
  @@map("sessions")
}
